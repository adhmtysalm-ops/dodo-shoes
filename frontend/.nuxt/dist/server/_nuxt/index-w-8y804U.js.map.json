{"file":"index-w-8y804U.js","mappings":";;;;;;;;;;;;;;;;;;;;AAqEA,UAAM,SAAS,iBAAA;AACf,UAAM,EAAE,MAAM,UAAU,SAAS,MAAA,IAAU;AAAA,MAAS,GAAG,OAAO,OAAO,MAAM;AAAA,MAAA;AAAA;AAAA,IAAA;;;;QArEpE,KAAI;AAAA,QAAM,OAAM;AAAA,MAAA;;QAoBH,IAAG;AAAA,QAAQ,OAAM;AAAA,MAAA;yBAA3B,CAEW,GAAAA,QAAAC,UAAA,aAAA;;;;;8BAF8I,iBAEzJ;AAAA,YAAA;AAAA;;;;;QACU,IAAG;AAAA,QAAI,OAAM;AAAA,MAAA;yBAAvB,CAEW,GAAAD,QAAAC,UAAA,aAAA;;;;;8BAFsK,gBAEjL;AAAA,YAAA;AAAA;;;;;;QASQ,IAAG;AAAA,QAAI,OAAM;AAAA,MAAA;yBAAvB,CAA6G,GAAAD,QAAAC,UAAA,aAAA;;;;;8BAAnB,UAAQ;AAAA,YAAA;AAAA;;;;;UAGzFC,MAAA,OAAA,GAAO;;iBACFA,MAAA,KAAA,GAAK;;;;AAICC,sBAAAD,MAAA,QAAA,IAAX,YAAO;;YACb,KAAK,QAAQ;AAAA,YACb,IAAE,aAAe,QAAQ,EAAE;AAAA,YAC5B,OAAM;AAAA,UAAA;6BAJR,CAoBW,GAAAF,QAAAC,UAAA,aAAA;;+OAXJ,OAAK,QAAQ,IAAI,wOAMoBG,eAAA,QAAQ,IAAI,mHAGzBA,eAAA,QAAQ,KAAK;;;kBAZ1CC,YAMM,OAAA,EAND,OAAM,iEAA6D;AAAA,oBACrEA,YAIC,OAAA;AAAA,sBAHA,KAAI;AAAA,sBACH,KAAK,QAAQ;AAAA,sBACd,OAAM;AAAA,oBAAA;;kBAGVA,YAMM,OAAA,EAND,OAAM,sCAAkC;AAAA,oBAC3CA,YAGM,OAAA,MAAA;AAAA,sBAFJA,YAA0D,QAAtD,OAAM,yBAAA,GAAwBC,gBAAI,QAAQ,IAAI,GAAA,CAAA;AAAA,sBAClDD,YAAsD,KAAA,EAAnD,OAAM,6BAAA,GAA6B,cAAY;AAAA,oBAAA;oBAEpDA,YAA+C,KAAA,EAA5C,OAAM,cAAA,GAAc,MAACC,gBAAG,QAAQ,KAAK,GAAA,CAAA;AAAA,kBAAA;;;;;;;;;;;;;;;;;;;","names":["_push","_parent","_unref","_ssrRenderList","_ssrInterpolate","_createVNode","_toDisplayString"],"sources":["../../../../pages/index.vue"],"sourcesContent":["<template>\n  <div dir=\"rtl\" class=\"font-sans\">\n    <!-- Hero Section -->\n    <div class=\"relative bg-brand-gray overflow-hidden\">\n      <div class=\"absolute inset-0\">\n        <img \n          src=\"https://images.unsplash.com/photo-1542291026-7eec264c27ff?auto=format&fit=crop&q=80&w=2000\" \n          alt=\"Hero background\" \n          class=\"w-full h-full object-cover object-center\"\n        />\n        <div class=\"absolute inset-0 bg-black/40\"></div>\n      </div>\n      \n      <div class=\"relative max-w-7xl mx-auto px-6 py-32 sm:py-48 lg:py-56 flex flex-col items-start justify-center min-h-[80vh]\">\n        <h1 class=\"text-5xl md:text-8xl font-black text-brand-white uppercase tracking-tighter mb-6 max-w-3xl leading-none\">\n          أطلق العنان <br/><span class=\"text-brand-red\">لقدراتك</span>\n        </h1>\n        <p class=\"mt-4 text-xl text-gray-200 max-w-xl mb-10 font-medium\">\n          اختبر الجيل القادم من الأحذية الرياضية. مصممة للسرعة والأبطال.\n        </p>\n        <div class=\"flex flex-col sm:flex-row gap-4\">\n          <NuxtLink to=\"#shop\" class=\"bg-brand-white text-brand-black px-10 py-4 rounded-full font-bold uppercase hover:bg-gray-200 transition-colors text-center\">\n            تسوق التشكيلة\n          </NuxtLink>\n          <NuxtLink to=\"/\" class=\"bg-transparent border-2 border-brand-white text-brand-white px-10 py-4 rounded-full font-bold uppercase hover:bg-white/10 transition-colors text-center\">\n            شاهد الفيديو\n          </NuxtLink>\n        </div>\n      </div>\n    </div>\n\n    <!-- Featured Products -->\n    <div id=\"shop\" class=\"max-w-7xl mx-auto px-6 py-24\">\n      <div class=\"flex justify-between items-end mb-12\">\n        <h2 class=\"text-3xl md:text-5xl font-black uppercase tracking-tight\">الرائج الآن</h2>\n        <NuxtLink to=\"/\" class=\"hidden md:block font-bold hover:text-brand-red transition-colors\">عرض الكل</NuxtLink>\n      </div>\n\n      <div v-if=\"pending\" class=\"py-20 text-center font-bold\">جاري تحميل المنتجات...</div>\n      <div v-else-if=\"error\" class=\"py-20 text-center text-brand-red font-bold\">حدث خطأ أثناء التحميل</div>\n      \n      <div v-else class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12\">\n        <NuxtLink \n          v-for=\"product in products\" \n          :key=\"product.id\" \n          :to=\"`/products/${product.id}`\" \n          class=\"group block\"\n        >\n          <div class=\"bg-brand-gray aspect-square mb-4 overflow-hidden rounded-xl\">\n             <img \n              src=\"https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?auto=format&fit=crop&q=80&w=800\" \n              :alt=\"product.name\"\n              class=\"object-cover w-full h-full group-hover:scale-105 transition-transform duration-500\"\n            />\n          </div>\n          <div class=\"flex justify-between items-start\">\n            <div>\n              <h3 class=\"font-bold text-lg mb-1\">{{ product.name }}</h3>\n              <p class=\"text-gray-500 text-sm mb-2\">أحذية رجالية</p>\n            </div>\n            <p class=\"font-medium\">${{ product.price }}</p>\n          </div>\n        </NuxtLink>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nconst config = useRuntimeConfig()\nconst { data: products, pending, error } = useFetch(`${config.public.apiUrl}/api/products`)\n</script>\n"],"version":3}